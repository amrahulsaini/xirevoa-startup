generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Prisma 7 takes the connection URL from prisma.config.ts (for migrations) and
// from the driver adapter passed to PrismaClient (at runtime), not from here.
datasource db {
  provider = "postgresql"
}

/// ─────────────────────────── Auth (Auth.js) ───────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  /// Chosen at sign-up, shown around the app. Unique, case-insensitive by
  /// convention (we lowercase before storing).
  username String? @unique

  /// bcrypt hash. Null for accounts created purely through Google — those users
  /// never set a password and sign in through the OAuth provider instead.
  passwordHash String?

  /// The shopper's saved try-on photo, so they don't re-upload every visit.
  /// Storage key, not a URL — the driver decides how to serve it.
  photoKey String?

  /// Spendable balance. Never write this directly — go through spend()/grant()
  /// in lib/xpoints so the ledger and the balance can't drift apart.
  xpoints Int @default(0)

  accounts Account[]
  sessions Session[]
  looks    Look[]
  store    Store?
  xpointTx XPointTx[]
  orders   Order[]
}

/// ────────────────────────── XPoints economy ───────────────────────────

enum XPointReason {
  signup_bonus
  tryon
  haircut
  purchase
  refund
  admin
}

/// Append-only ledger. The User.xpoints balance is a cache of this; every
/// change writes a row, so a disputed balance can always be reconstructed.
model XPointTx {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Positive = credit, negative = debit.
  delta   Int
  reason  XPointReason
  /// Balance immediately after this row was applied — makes audits trivial.
  balance Int
  /// Free-text context: which look, which order.
  note    String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

enum OrderStatus {
  created
  paid
  failed
}

/// A Razorpay purchase of XPoints.
model Order {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Razorpay's order id (order_xxx) and, once captured, the payment id.
  razorpayOrderId   String  @unique
  razorpayPaymentId String?

  /// What they bought. Amount is in paise — never store money as a float.
  packId       String
  amountPaise  Int
  xpoints      Int

  status    OrderStatus @default(created)
  createdAt DateTime    @default(now())
  paidAt    DateTime?

  @@index([userId, createdAt])
}

/// ──────────────────────── Free-grant abuse guard ──────────────────────
///
/// Signup bonuses are real money (20 XPoints ≈ 2 try-ons ≈ ₹26 of Gemini spend),
/// so they can't be farmed by clearing cookies or opening an incognito window.
/// We record the device fingerprint and a hashed IP of every free grant.
///
/// Fingerprint is the strong signal and is unique — one free grant per device.
/// IP is deliberately NOT unique: most Indian mobile traffic is behind CGNAT, so
/// thousands of legitimate users share one address. It's rate-limited instead.
model FreeGrant {
  id String @id @default(cuid())

  /// Hash of the browser fingerprint. Unique: a device gets the bonus once.
  fingerprint String @unique

  /// Hashed IP — never store a raw IP we don't need.
  ipHash String

  userId    String
  createdAt DateTime @default(now())

  @@index([ipHash, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

/// ────────────────────────────── Catalog ───────────────────────────────

enum Category {
  tshirt
  shirt
  jeans
  jacket
  dress
  shoes
  glasses
  jewellery
}

/// A garment a shopper can try on.
///
/// `storeId` is null for Xirevoa's own founding collection. Once local stores
/// onboard, their inventory lands in this same table with storeId set — the
/// try-on engine doesn't care who owns the garment.
model Garment {
  id       String   @id @default(cuid())
  slug     String   @unique
  name     String
  category Category
  /// Fit variant shoppers filter on: Baggy, Straight, Bootcut, Slim…
  fit      String?
  tagline  String?

  /// Storage key of the flat-lay product shot fed to the try-on engine.
  imageKey String

  /// Deliberately nullable. We show no prices while onboarding stores —
  /// shoppers are here to see themselves in the garment, not to buy yet.
  priceInPaise Int?

  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  published Boolean  @default(true)
  createdAt DateTime @default(now())

  looks LookGarment[]

  @@index([category, published])
  @@index([storeId])
}

/// ──────────────────────────────── Looks ───────────────────────────────

/// One completed try-on: a person + the garments they wore + the result.
model Look {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Storage key of the generated image.
  imageKey String

  /// Hash of (photo + garments). Lets us serve a repeat request from storage
  /// instead of paying Gemini for an image we already have.
  cacheKey String @unique

  /// Off by default. A look is a photo of the user's face — it only becomes
  /// publicly reachable if they explicitly share it.
  shared    Boolean  @default(false)
  createdAt DateTime @default(now())

  garments LookGarment[]

  @@index([userId, createdAt])
}

model LookGarment {
  lookId    String
  garmentId String
  look      Look    @relation(fields: [lookId], references: [id], onDelete: Cascade)
  garment   Garment @relation(fields: [garmentId], references: [id], onDelete: Cascade)

  @@id([lookId, garmentId])
}

/// ──────────────────────────────── Stores ──────────────────────────────

enum StoreStatus {
  pending
  approved
  rejected
}

/// A local clothing store listing its stock on Xirevoa.
model Store {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name  String
  slug  String @unique
  city  String
  state String
  phone String?

  /// Stores are manually reviewed before their stock goes live — one bad
  /// listing on a try-on site is a trust problem, not just a content problem.
  status    StoreStatus @default(pending)
  createdAt DateTime    @default(now())

  garments Garment[]

  @@index([status])
}
