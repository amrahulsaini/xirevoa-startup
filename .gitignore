# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — secrets never get committed
.env*
!.env.example

# credentials
*-service-account*.json
gcp-key*.json

# Try-on results are photos of real people — never commit them.
/storage

# NOTE: public/catalog and public/showcase ARE committed on purpose.
# Generation is non-deterministic, so re-seeding would silently produce a
# different collection. They're product assets, not build artifacts.

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma client is generated from schema.prisma at build time
/src/generated

# Deploy-time secrets — the generated startup script contains the DB password
deploy/.dbpass
deploy/.env.production
deploy/.startup.generated.sh

# Temporary brand picker — delete once the logo/spinner are chosen
/public/brand.html

# stray dev scratch
/q.sh
/*.mjs

# deploy tarballs — never commit
*.tgz
deploy/.remote-build.lf.sh
deploy/.setup-dbui.lf.sh
